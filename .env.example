# 文本聊天模型
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro

# 知识库向量模型：导入资料/RAG 检索需要
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
EMBEDDING_MODEL=text-embedding-v3

# 网页小助手 / Computer Use：多模态理解模型，看截图 + DOM 后输出点击/输入动作 JSON。
# 当前项目默认走 gcloud / Google Vertex，不是图片生成接口，也不是普通网页搜索接口。
VISION_PROVIDER=google-vertex
GOOGLE_VERTEX_PROJECT=your_google_cloud_project_id
GOOGLE_VERTEX_LOCATION=global
GOOGLE_VERTEX_VISION_MODEL=gemini-2.5-flash-lite
GOOGLE_VERTEX_VISION_FALLBACK_MODELS=gemini-2.5-flash,gemini-3.1-flash-lite,gemini-3.1-pro-preview

# 可选：如果不用 Vertex，也可以改成 OpenAI-compatible 多模态接口。
# VISION_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
# VISION_API_KEY=your_vision_api_key_here
# VISION_MODEL=gemini-2.5-flash
# VISION_FALLBACK_MODELS=gemini-2.5-flash-lite,qwen-vl-plus

# 网页资料查询：默认使用本地浏览器搜索，不再依赖外部搜索网关。
XUEMATE_QUICK_SEARCH_MODE=local

# 直连本机地址，避免代理拦截内网请求。
NO_PROXY=127.0.0.1,localhost
no_proxy=127.0.0.1,localhost
# PeerEdge 班级边缘协同网络（Rust sidecar，后台隐藏；auto 表示二进制存在时自动启动）
XUEMATE_PEEREDGE=auto
XUEMATE_PEEREDGE_PORT=18888
# 本地开发可用 127.0.0.1；班级局域网协同可改为 0.0.0.0。
XUEMATE_PEEREDGE_BIND=127.0.0.1
# 对外广播地址不建议写死；不填时 Rust 会根据 bind 自动推导。
# XUEMATE_PEEREDGE_PUBLIC_URL=auto
XUEMATE_PEEREDGE_GROUP=class-demo
# auto = mDNS 自动发现 + seed 调试兜底；seed = 只读 XUEMATE_PEEREDGE_SEEDS；mdns = 只用 mDNS；off = 不发现 peer。
XUEMATE_PEEREDGE_DISCOVERY=auto
XUEMATE_PEEREDGE_MDNS_SERVICE=_xm-edge._tcp.local.
XUEMATE_PEEREDGE_MDNS_PORT=5353
# 仅本机多节点调试时才打开；真实班级局域网不要广播 127.0.0.1。
XUEMATE_PEEREDGE_MDNS_ALLOW_LOOPBACK=0
XUEMATE_PEEREDGE_TIMEOUT_MS=650
XUEMATE_PEEREDGE_FANOUT=4
# 多节点调试时填种子，不走前端手动添加：
# XUEMATE_PEEREDGE_SEEDS=http://127.0.0.1:18889,http://127.0.0.1:18890
