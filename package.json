{
  "name": "xuemate-app",
  "version": "1.0.0",
  "description": "An Electron application with Vue",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "rebuild:native": "electron-builder install-app-deps",
    "bench:rag": "node scripts/rag-benchmark.mjs",
    "bench:memory": "node scripts/memory-benchmark.mjs",
    "cloud:dev": "node cloud/gateway/server.mjs",
    "cloud:docker": "cd cloud && docker compose up -d",
    "cloud:docker:ps": "cd cloud && docker compose ps",
    "cloud:docker:down": "cd cloud && docker compose down",
    "cloud:docker:light": "cd cloud && docker compose up -d",
    "cloud:docker:full": "cd cloud && docker compose -f docker-compose.yml -f docker-compose.full.yml up -d",
    "cloud:docker:server": "cd cloud && docker compose -f docker-compose.yml -f docker-compose.full.yml -f docker-compose.server.yml up -d"
  },
  "dependencies": {
    "@electron-toolkit/preload": "3.0.2",
    "@electron-toolkit/utils": "4.0.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "marked": "^18.0.3",
    "pdf-parse": "2.4.5",
    "sigma": "^3.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "2.1.0",
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "25.6.0",
    "@vitejs/plugin-vue": "6.0.2",
    "electron": "39.2.6",
    "electron-builder": "26.0.12",
    "electron-vite": "5.0.0",
    "eslint": "9.39.1",
    "eslint-plugin-vue": "10.6.2",
    "prettier": "3.7.4",
    "typescript": "6.0.3",
    "vite": "7.2.6",
    "vue": "3.5.25",
    "vue-eslint-parser": "10.2.0"
  }
}
